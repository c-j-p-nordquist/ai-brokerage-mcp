# Default mode is safe and runs entirely from synthetic demo data.
AGENTIC_BROKERAGE_MCP_BROKER_MODE=demo
AGENTIC_BROKERAGE_MCP_BASE_CURRENCY=USD
AGENTIC_BROKERAGE_MCP_DB_PATH=~/.agentic-brokerage-mcp/state.db
AGENTIC_BROKERAGE_MCP_LOG_LEVEL=INFO

# Live mode requires your own Interactive Brokers Client Portal / iBeam setup.
# Keep live trading disabled unless you intentionally want submit/cancel/modify
# tools to touch a real account.
AGENTIC_BROKERAGE_MCP_IBKR_BASE_URL=https://localhost:5001/v1/api
AGENTIC_BROKERAGE_MCP_IBKR_ACCOUNT_ID=
AGENTIC_BROKERAGE_MCP_IBKR_VERIFY_SSL=false
AGENTIC_BROKERAGE_MCP_ENABLE_LIVE_TRADING=false
